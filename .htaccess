<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /mhb/

  # Don't rewrite actual files or directories
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Don't rewrite backend requests
  RewriteCond %{REQUEST_URI} !^/mhb/mhb_be/

  # All other requests → Vue's index.html (for client-side routing)
  RewriteRule ^ index.html [L]
</IfModule>